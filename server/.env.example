# ── Server ────────────────────────────────────────────────────────────────────
PORT=8002
NODE_ENV=production

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
DB=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Razorpay (payments) ────────────────────────────────────────────────────────
Razorpay_Key=rzp_live_xxxxxxxxxxxxxxxxxxxx
Razorpay_Secret=your_razorpay_secret

# ── JWT Secrets (use long random strings) ────────────────────────────────────
Jwt_Sec=your_jwt_secret_min_32_chars
Activation_Secret=your_activation_secret
Forgot_Secret=your_forgot_secret
Refresh_Secret=your_refresh_secret

# ── Email / Gmail SMTP ────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM=your@gmail.com

# ── Cloudinary (image / file storage) ────────────────────────────────────────
# Create free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
# Set this to your Cloudflare Pages domain after deploying
frontendurl=https://your-app.pages.dev
